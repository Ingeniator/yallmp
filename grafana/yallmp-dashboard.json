{
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "stat", "name": "Stat" },
    { "type": "panel", "id": "table", "name": "Table" }
  ],
  "id": null,
  "uid": "yallmp-overview",
  "title": "yallmp Overview",
  "description": "LLM proxy gateway: request rates, latencies, token usage, cost tracking, and circuit breaker health",
  "tags": ["yallmp", "prometheus"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "current": {},
        "options": [],
        "regex": ""
      },
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(http_requests_total, job)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {}
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(http_requests_total{job=~\"$job\"}, instance)",
        "refresh": 2,
        "allValue": ".*",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "group_id",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(http_requests_total{job=~\"$job\"}, group_id)",
        "refresh": 2,
        "allValue": ".*",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "model",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(llm_requests_total{group_id=~\"$group_id\"}, model)",
        "refresh": 2,
        "allValue": ".*",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "HTTP Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Request Rate",
      "type": "stat",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum(rate(http_requests_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "stat",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum(rate(http_requests_total{job=~\"$job\", instance=~\"$instance\", status_code=~\"5..\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "P95 Latency",
      "type": "stat",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])) by (le))",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "LLM Requests / min",
      "type": "stat",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum(rate(llm_requests_total{group_id=~\"$group_id\"}[$__rate_interval])) * 60",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum by (endpoint) (rate(http_requests_total{job=~\"$job\", instance=~\"$instance\", group_id=~\"$group_id\"}[$__rate_interval]))",
          "legendFormat": "{{ endpoint }}"
        }
      ]
    },
    {
      "title": "Request Rate by Status Code",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "2.." }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "4.." }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "5.." }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum by (status_code) (rate(http_requests_total{job=~\"$job\", instance=~\"$instance\", group_id=~\"$group_id\"}[$__rate_interval]))",
          "legendFormat": "{{ status_code }}"
        }
      ]
    },
    {
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\", instance=~\"$instance\", group_id=~\"$group_id\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": "${datasource}",
          "expr":"histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\", instance=~\"$instance\", group_id=~\"$group_id\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": "${datasource}",
          "expr":"histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\", instance=~\"$instance\", group_id=~\"$group_id\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Latency by Endpoint (p95)",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"histogram_quantile(0.95, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket{job=~\"$job\", instance=~\"$instance\", group_id=~\"$group_id\"}[$__rate_interval])))",
          "legendFormat": "{{ endpoint }}"
        }
      ]
    },
    {
      "title": "LLM Proxy Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "LLM Requests by Model",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum by (model) (rate(llm_requests_total{group_id=~\"$group_id\", model=~\"$model\"}[$__rate_interval]))",
          "legendFormat": "{{ model }}"
        }
      ]
    },
    {
      "title": "LLM Requests by Provider",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum by (provider) (rate(llm_requests_total{group_id=~\"$group_id\"}[$__rate_interval]))",
          "legendFormat": "{{ provider }}"
        }
      ]
    },
    {
      "title": "Token Usage",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Total Tokens / min",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum by (model) (rate(llm_total_token_usage_total{group_id=~\"$group_id\", model=~\"$model\"}[$__rate_interval])) * 60",
          "legendFormat": "{{ model }}"
        }
      ]
    },
    {
      "title": "Prompt vs Completion Tokens / min",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "prompt.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "completion.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum(rate(llm_prompt_token_usage_total{group_id=~\"$group_id\", model=~\"$model\"}[$__rate_interval])) * 60",
          "legendFormat": "prompt"
        },
        {
          "datasource": "${datasource}",
          "expr":"sum(rate(llm_completion_token_usage_total{group_id=~\"$group_id\", model=~\"$model\"}[$__rate_interval])) * 60",
          "legendFormat": "completion"
        }
      ]
    },
    {
      "title": "Tokens by Group",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum by (group_id) (rate(llm_total_token_usage_total{group_id=~\"$group_id\", group_id!=\"\", model=~\"$model\"}[$__rate_interval])) * 60",
          "legendFormat": "{{ group_id }}"
        }
      ]
    },
    {
      "title": "Cost",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Cost Rate by Model ($/hr)",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum by (model) (rate(llm_cost_total{group_id=~\"$group_id\", model=~\"$model\"}[$__rate_interval])) * 3600",
          "legendFormat": "{{ model }}"
        }
      ]
    },
    {
      "title": "Cost Rate by Group ($/hr)",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum by (group_id) (rate(llm_cost_total{group_id=~\"$group_id\", group_id!=\"\"}[$__rate_interval])) * 3600",
          "legendFormat": "{{ group_id }}"
        }
      ]
    },
    {
      "title": "Circuit Breaker",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "503 Responses (Circuit Breaker)",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 15 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum(rate(http_requests_total{job=~\"$job\", instance=~\"$instance\", status_code=\"503\"}[$__rate_interval])) * 60",
          "legendFormat": "503s/min"
        }
      ]
    },
    {
      "title": "Request Rate by Group",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 51 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr":"sum by (group_id) (rate(http_requests_total{job=~\"$job\", instance=~\"$instance\", group_id=~\"$group_id\", group_id!=\"\"}[$__rate_interval]))",
          "legendFormat": "{{ group_id }}"
        }
      ]
    },
    {
      "title": "Period Totals",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 60 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Total Tokens (selected period)",
      "type": "stat",
      "datasource": "${datasource}",
      "description": "Total LLM tokens consumed over the dashboard's selected time range, filtered by the current group/model.",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 61 },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "thresholds": { "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      },
      "options": { "graphMode": "none", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum(increase(llm_total_token_usage_total{group_id=~\"$group_id\", model=~\"$model\"}[$__range]))",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "title": "LLM Requests (selected period)",
      "type": "stat",
      "datasource": "${datasource}",
      "description": "Total LLM completion requests proxied over the dashboard's selected time range, filtered by the current group/model.",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 61 },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "graphMode": "none", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum(increase(llm_requests_total{group_id=~\"$group_id\", model=~\"$model\"}[$__range]))",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "title": "Cost Spent (selected period)",
      "type": "stat",
      "datasource": "${datasource}",
      "description": "Total estimated LLM cost over the dashboard's selected time range, filtered by the current group/model.",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 61 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 2, "thresholds": { "steps": [{ "color": "orange", "value": null }] } },
        "overrides": []
      },
      "options": { "graphMode": "none", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum(increase(llm_cost_total{group_id=~\"$group_id\", model=~\"$model\"}[$__range]))",
          "legendFormat": "",
          "instant": true
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 5
}
