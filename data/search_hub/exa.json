{
  "name": "exa",
  "type": "exa",
  "base_url": "https://api.exa.ai",
  "auth": {
    "type": "APIKEY",
    "api_key": "${EXA_API_KEY}"
  },
  "default": false,
  "cost_per_search": 0.001,
  "timeout": {
    "connect": 10,
    "read": 30,
    "write": 10
  },
  "failure_threshold": 5,
  "recovery_time": 30,
  "window_size": 60
}
