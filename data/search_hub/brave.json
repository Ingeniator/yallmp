{
  "name": "brave",
  "type": "brave",
  "base_url": "https://api.search.brave.com",
  "auth": {
    "type": "APIKEY",
    "api_key": "${BRAVE_SEARCH_API_KEY}"
  },
  "default": false,
  "cost_per_search": 0.0,
  "timeout": {
    "connect": 10,
    "read": 15,
    "write": 10
  },
  "failure_threshold": 5,
  "recovery_time": 30,
  "window_size": 60
}
